{
    "name": "dylvn/oro-mate-extension",
    "description": "OroCommerce introspection extension for Symfony AI Mate",
    "type": "symfony-ai-mate",
    "license": "MIT",
    "keywords": [
        "ai",
        "mcp",
        "orocommerce",
        "datagrid",
        "mate"
    ],
    "require": {
        "php": ">=8.2",
        "symfony/ai-mate": "^0.8",
        "symfony/finder": "^7.0|^8.0",
        "symfony/yaml": "^7.0|^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Dylvn\\OroMateExtension\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/ai-mate-composer-plugin": true
        }
    },
    "extra": {
        "ai-mate": {
            "scan-dirs": [
                "src/Capability"
            ],
            "includes": [
                "config/config.php"
            ],
            "instructions": "INSTRUCTIONS.md"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Mate\\": "mate/src/"
        }
    }
}
